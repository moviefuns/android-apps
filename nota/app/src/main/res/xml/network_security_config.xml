<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows connections to self-hosted Nextcloud instances that use
    certificates signed by user-installed CAs (e.g. Let's Encrypt on
    internal domains, or a private CA on the homelab).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config>
        <domain includeSubdomains="true">103.233.74.57</domain>
        <trust-anchors>
            <certificates src="@raw/cert"/>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
